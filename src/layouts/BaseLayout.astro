---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'A learning community for Filipino knowledge workers exploring AI.' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} | Weekend AI Stuff</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">Weekend AI Stuff</a>
      <ul class="nav-links">
        <li><a href="/">Home</a></li>
        <li><a href="/challenges/">Challenges</a></li>
      </ul>
    </div>
  </nav>

  <slot />

  <footer class="footer">
    <p>Weekend AI Stuff &copy; {new Date().getFullYear()}</p>
    <p style="margin-top: 0.5rem;">Weekdays for work. Weekends to upskill.</p>
  </footer>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
