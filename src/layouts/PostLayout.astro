---
import BaseLayout from './BaseLayout.astro';

interface Props {
  frontmatter: {
    title: string;
    description: string;
    date: string;
    type: string;
    complexity: string;
    quickWin?: string;
    access: string;
  };
}

const { frontmatter } = Astro.props;

function formatDate(dateStr: string) {
  const date = new Date(dateStr + 'T00:00:00');
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}

function typeLabel(type: string) {
  const labels: Record<string, string> = {
    challenge: 'Challenge',
    resource: 'Resource Drop',
    nudge: 'Nudge',
  };
  return labels[type] || type;
}
---
<BaseLayout title={frontmatter.title} description={frontmatter.description}>
  <article class="post">
    <a href="/challenges/" class="back-link">&larr; All Challenges</a>

    <header class="post-header">
      <h1>{frontmatter.title}</h1>
      <p class="description">{frontmatter.description}</p>
      <div class="post-meta">
        <span class="post-date">{formatDate(frontmatter.date)}</span>
        <span class={`tag type-${frontmatter.type}`}>{typeLabel(frontmatter.type)}</span>
        <span class="tag">Complexity: {frontmatter.complexity}</span>
        {frontmatter.quickWin && <span class="tag">{frontmatter.quickWin}</span>}
        <span class="tag">{frontmatter.access}</span>
      </div>
    </header>

    <div class="prose">
      <slot />
    </div>
  </article>
</BaseLayout>
