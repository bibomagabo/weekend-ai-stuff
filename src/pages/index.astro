---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allChallenges = await getCollection('challenges');
const sortedChallenges = allChallenges.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
const latestChallenges = sortedChallenges.slice(0, 3);

function formatDate(dateStr: string) {
  const date = new Date(dateStr + 'T00:00:00');
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}

function typeLabel(type: string) {
  const labels: Record<string, string> = {
    challenge: 'Challenge',
    resource: 'Resource Drop',
    nudge: 'Nudge',
  };
  return labels[type] || type;
}
---
<BaseLayout title="Home">

  <section class="hero">
    <div class="hero-inner">
      <div class="hero-text">
        <h1>Make AI Work <span class="accent">For You</span></h1>
        <p>
          A small community of Filipino knowledge workers learning to use AI in their actual jobs.
          No jargon. No pressure. Just practical prompts you can try this weekend.
        </p>
        <a href="/challenges/" class="hero-cta">See the Challenges</a>
      </div>
      <div class="hero-visual">
        {latestChallenges[0] && (
          <div class="hero-preview-card">
            <div class="hero-preview-label">Latest Drop</div>
            <div class="hero-preview-title">{latestChallenges[0].data.title}</div>
            <div class="hero-preview-meta">
              <span class={`tag type-${latestChallenges[0].data.type}`}>{typeLabel(latestChallenges[0].data.type)}</span>
              <span class="tag">Complexity: {latestChallenges[0].data.complexity}</span>
            </div>
            <p class="hero-preview-excerpt">{latestChallenges[0].data.description}</p>
            <a href={`/challenges/${latestChallenges[0].slug}/`} class="hero-preview-link">Try this challenge →</a>
          </div>
        )}
      </div>
    </div>
  </section>

  <div class="stat-bar">
    <div class="stat-bar-inner">
      <div>
        <span class="stat-number">15–30</span>
        <span class="stat-label">minutes per challenge</span>
      </div>
      <div>
        <span class="stat-number">100%</span>
        <span class="stat-label">free tools only</span>
      </div>
      <div>
        <span class="stat-number">PH</span>
        <span class="stat-label">context &amp; examples</span>
      </div>
      <div>
        <span class="stat-number">Weekly</span>
        <span class="stat-label">new drops</span>
      </div>
    </div>
  </div>

  <section class="section">
    <h2 class="section-title">How this works</h2>
    <p class="section-subtitle">Weekdays for work. Weekends to upskill.</p>

    <div class="values-grid">
      <div class="value-card">
        <h3>Weekend Challenges</h3>
        <p>Short, practical prompts you can try in 15 to 30 minutes. Each one teaches you something real about working with AI.</p>
      </div>
      <div class="value-card">
        <h3>Built for Your Context</h3>
        <p>Prompts designed for Filipino knowledge workers in BPO, corporate, and remote work settings. Not generic advice from the internet.</p>
      </div>
      <div class="value-card">
        <h3>Free Tools Only</h3>
        <p>Everything runs on Google Gemini (free) or similar tools you already have access to. No paid subscriptions needed to start.</p>
      </div>
      <div class="value-card">
        <h3>Learn by Doing</h3>
        <p>No lectures, no courses, no live calls. Just weekly drops you can act on at your own pace, from your phone or laptop.</p>
      </div>
    </div>
  </section>

  <section class="section" style="padding-top: 0;">
    <h2 class="section-title">Latest</h2>
    <p class="section-subtitle">The most recent drops from the community.</p>

    <div class="challenge-grid">
      {latestChallenges.map((challenge) => (
        <a href={`/challenges/${challenge.slug}/`} class="challenge-card">
          <div class="challenge-card-meta">
            <span class={`tag type-${challenge.data.type}`}>{typeLabel(challenge.data.type)}</span>
            <span class="tag">Complexity: {challenge.data.complexity}</span>
          </div>
          <h3>{challenge.data.title}</h3>
          <p>{challenge.data.description}</p>
          <div class="challenge-card-date">{formatDate(challenge.data.date)}</div>
        </a>
      ))}
    </div>
  </section>

</BaseLayout>
