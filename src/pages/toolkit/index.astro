---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allTools = await getCollection('toolkit');
const sortedTools = allTools.sort((a, b) =>
  new Date(b.data.dateAdded).getTime() - new Date(a.data.dateAdded).getTime()
);

function easeClass(ease: string) {
  if (ease === 'Beginner-friendly') return 'ease-beginner';
  if (ease === 'Some setup needed') return 'ease-moderate';
  return 'ease-advanced';
}
---
<BaseLayout title="Your AI Toolkit">
  <section class="section">
    <h2 class="section-title">Your AI Toolkit</h2>
    <p class="section-subtitle">Free AI tools you can start using today. Each one includes a quick starter action you can try in under 5 minutes.</p>

    <div class="challenge-list">
      {sortedTools.map((tool) => (
        <a href={`/toolkit/${tool.slug}/`} class="challenge-card">
          <div class="challenge-card-meta">
            {tool.data.tags.map((tag) => (
              <span class="tag tag-category">{tag}</span>
            ))}
            <span class={`tag ${easeClass(tool.data.easeOfUse)}`}>{tool.data.easeOfUse}</span>
          </div>
          <h3>{tool.data.title}</h3>
          <p>{tool.data.oneLiner}</p>
          <div class="tool-card-footer">
            <span class="tag">{tool.data.access}</span>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
